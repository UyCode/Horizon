{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "${OPENAI_MODEL}",
    "base_url": "${OPENAI_BASE_URL}",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 2,
    "enrichment_concurrency": 2,
    "languages": [
      "en",
      "zh"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "UyCode",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Blog Changelog",
        "url": "https://github.blog/changelog/feed/",
        "enabled": true,
        "category": "developer-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "programming",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 75
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "twitter": {
      "enabled": false,
      "users": [],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": [
        "All",
        "Python",
        "TypeScript"
      ],
      "keywords": [],
      "min_stars": 25,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  },
  "email": {
    "enabled": true,
    "smtp_server": "${HORIZON_SMTP_SERVER}",
    "smtp_port": "${HORIZON_SMTP_PORT}",
    "smtp_username": "${HORIZON_SMTP_USERNAME}",
    "imap_enabled": false,
    "imap_server": "imap.example.com",
    "imap_port": 993,
    "email_address": "${HORIZON_EMAIL_ADDRESS}",
    "password_env": "HORIZON_EMAIL_PASSWORD",
    "sender_name": "${HORIZON_EMAIL_SENDER_NAME}",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
